<!DOCTYPE html>
<html ng-app="locationApp">
<head>
  <title>Current Page Location</title>
  <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
</head>

<body ng-controller="LocationController">

  <h2>Current Web Page Location</h2>

  <p><strong>Full URL:</strong> {{ location.href }}</p>
  <p><strong>Protocol:</strong> {{ location.protocol }}</p>
  <p><strong>Host:</strong> {{ location.host }}</p>
  <p><strong>Pathname:</strong> {{ location.pathname }}</p>

  <script>
    var app = angular.module("locationApp", []);

    app.controller("LocationController", function($scope, $window) {
      $scope.location = $window.location;
    });
  </script>

</body>
</html>

