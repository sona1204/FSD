<!DOCTYPE html>
<html ng-app="myApp">
<head>
    <title>AngularJS Validation</title>
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
</head>
<body ng-controller="FormController">

    <h2>User Validation Form</h2>

    <form name="userForm" ng-submit="validate()">
        <label>Username:</label>
        <input type="text" ng-model="username" required />
        <br><br>
        <label>Password:</label>
        <input type="password" ng-model="password" required />
        <br><br>
        <button type="submit">Submit</button>
    </form>

    <script>
        angular.module('myApp', [])
        .controller('FormController', ['$scope', function($scope) {
            $scope.validate = function() {
               
                if (!$scope.username || $scope.username.trim() === '') {
                    alert("Enter username");
                    return;
                }
                if ($scope.username.length < 3) {
                    alert("Username is too short");
                    return;
                }

                if (!$scope.password || $scope.password.length < 8) {
                    alert("Password must be at least 8 characters");
                    return;
                }

                alert("Valid username and password");
            };
        }]);
    </script>

</body>
</html>
