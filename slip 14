<!DOCTYPE html>
<html>
<head>
    <title>Employee Registration</title>
    <script>
        function validateForm() {
            let dob = new Date(document.getElementById("dob").value);
            let joiningDate = new Date(document.getElementById("joiningDate").value);
            let salary = document.getElementById("salary").value;

            let today = new Date();

            // DOB validation (must be past date and age >= 18)
            let age = today.getFullYear() - dob.getFullYear();
            if (dob >= today || age < 18) {
                alert("Invalid DOB. Employee must be at least 18 years old.");
                return false;
            }

            // Joining Date validation (must be after DOB and not in future)
            if (joiningDate <= dob || joiningDate > today) {
                alert("Invalid Joining Date.");
                return false;
            }

            // Salary validation (must be positive)
            if (salary <= 0) {
                alert("Salary must be greater than 0.");
                return false;
            }

            alert("Form submitted successfully!");
            return true;
        }
    </script>
</head>

<body>
    <h2>Employee Registration Form</h2>

    <form onsubmit="return validateForm()">
        Name: <input type="text" required><br><br>

        DOB: <input type="date" id="dob" required><br><br>

        Joining Date: <input type="date" id="joiningDate" required><br><br>

        Salary: <input type="number" id="salary" required><br><br>

        <input type="submit" value="Register">
    </form>
</body>
</html>
