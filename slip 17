<!DOCTYPE html>
<html ng-app="mscApp">
<head>
    <meta charset="UTF-8">
    <title>M.Sc (CS) Sem-II Syllabus</title>
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular-route.min.js"></script>
</head>
<body>

    <h1>M.Sc (CS) Sem-II Syllabus</h1>
    
    <!-- Navigation Links -->
    <ul>
        <li><a href="#!/subject/DBMS">DBMS</a></li>
        <li><a href="#!/subject/OS">Operating Systems</a></li>
        <li><a href="#!/subject/Networking">Networking</a></li>
        <li><a href="#!/subject/AI">Artificial Intelligence</a></li>
    </ul>

    <!-- This is where the view content will be displayed -->
    <div ng-view></div>

    <script>
        var app = angular.module("mscApp", ["ngRoute"]);

        app.config(function($routeProvider){
            $routeProvider
            .when("/subject/:subjectName", {
                templateUrl: function(params){
                    return params.subjectName + ".html";
                },
                controller: "SyllabusController"
            })
            .otherwise({
                redirectTo: "/subject/DBMS"
            });
        });

        app.controller("SyllabusController", function($scope, $routeParams){
            $scope.subject = $routeParams.subjectName;
        });
    </script>
</body>
</html>

<h2>DBMS Syllabus</h2>
<ul>
    <li>Relational Model</li>
    <li>SQL Queries</li>
    <li>Normalization</li>
    <li>Transaction Management</li>
</ul>

